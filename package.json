{
  "name": "unplugin-oss",
  "version": "0.0.0",
  "description": "OSS plugin powered by unplugin.",
  "keywords": [
    "esbuild",
    "farm",
    "rolldown",
    "rollup",
    "rspack",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/Drswith/unplugin-oss#readme",
  "bugs": {
    "url": "https://github.com/Drswith/unplugin-oss/issues"
  },
  "license": "MIT",
  "author": "Drswith <540628938@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drswith/unplugin-oss.git"
  },
  "funding": "https://github.com/sponsors/Drswith",
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js",
    "./esbuild": "./dist/esbuild.js",
    "./farm": "./dist/farm.js",
    "./rolldown": "./dist/rolldown.js",
    "./rollup": "./dist/rollup.js",
    "./rspack": "./dist/rspack.js",
    "./vite": "./dist/vite.js",
    "./webpack": "./dist/webpack.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@sxzz/test-utils": "^0.5.16",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.0",
    "tsdown-preset-sxzz": "^0.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@11.5.2"
}
